<?xml version="1.0"?>
<robot xmlns:xacro="https://www.ros.org/wiki/xacro">


    <material name="red">
        <color rgba="1 0 0 1"/>
    </material>

    <material name="blue">
        <color rgba="0 0 1 1"/>
    </material>

    <material name="orange">
        <color rgba="1 0.3686 0.0196 1"/>
    </material>

    <material name="black">
        <color rgba="0 0 0 1"/>
    </material>

    <material name="green">
        <color rgba="0 1 0 1"/>
    </material>

    <!-- BASE LINK -->

    <link name="base_link"/>

    <!-- CHASSIS -->

    <link name="chassis">
        <visual>
            <origin xyz="0.25 0 0.1" rpy="0 0 0"/>
            <geometry>
                <box size="0.5 0.5 0.2"/>
            </geometry>
            <material name="orange"/>
        </visual>

        <collision>
            <origin xyz="0.25 0 0.1" rpy="0 0 0"/>
            <geometry>
                <box size="0.5 0.5 0.2"/>
            </geometry>
        </collision>

        <inertial>
            <origin xyz="0.25 0 0.1" rpy="0 0 0"/>
            <mass value="5.0"/>
            <inertia 
                ixx="0.1208"
                iyy="0.1208"
                izz="0.2083"
                ixy="0.0"
                ixz="0.0"
                iyz="0.0"/>
        </inertial>

    </link>

    <gazebo reference="chassis">
        <material>Gazebo/Red</material>
    </gazebo>

    <joint name="base_joint" type="fixed">
        <parent link="base_link"/>
        <child link="chassis"/>
        <origin xyz= "-0.15 0 0" rpy="0 0 0"/>
    </joint>

    <!-- LEFT WHEEL -->

    <joint name="left_wheel_joint" type="continuous">
        <parent link="base_link"/>
        <child link="left_wheel"/>
        <origin xyz="0 0.275 0" rpy="-1.5708 0 0"/>
        <axis xyz="0 0 1"/>
    </joint>


    <link name="left_wheel">
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <cylinder radius="0.08" length="0.05"/>
            </geometry>
            <material name="black"/>
        </visual>

        <collision>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <cylinder radius="0.08" length="0.05"/>
            </geometry>
            
        </collision>

        <inertial>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <mass value="2.0"/>
            <inertia 
                ixx="0.0010"
                iyy="0.0010"
                izz="0.0016"
                ixy="0.0"
                ixz="0.0"
                iyz="0.0"/>
        </inertial>

        
    </link>

    <gazebo reference="left_wheel">
        <material>Gazebo/Blue</material>
    </gazebo>

    <!-- RIGHT WHEEL -->

    <joint name="right_wheel_joint" type="continuous">
        <parent link="base_link"/>
        <child link="right_wheel"/>
        <origin xyz="0 -0.275 0" rpy="1.5708 0 0"/>
        <axis xyz="0 0 1"/>
    </joint>

    <link name="right_wheel">
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <cylinder radius="0.08" length="0.05"/>
            </geometry>
            <material name="black"/>
        </visual>
        <collision>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <cylinder radius="0.08" length="0.05"/>
            </geometry>
            
        </collision>

        <inertial>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <mass value="2.0"/>
            <inertia 
                ixx="0.0010"
                iyy="0.0010"
                izz="0.0016"
                ixy="0.0"
                ixz="0.0"
                iyz="0.0"/>
        </inertial>

    </link>

    <gazebo reference="right_wheel">
        <material>Gazebo/Blue</material>
    </gazebo>

    <!-- CASTER WHEEL -->
   
    <joint name="caster_wheel_joint" type="fixed">
        <parent link="chassis"/>
        <child link="caster_wheel"/>
        <origin xyz="0.38 0 0" rpy="0 0 0"/>
    </joint>

    <link name= "caster_wheel">
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <sphere radius="0.08"/>
            </geometry>
            <material name="red"/>
        </visual>
        <collision>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <sphere radius="0.08"/>
            </geometry>
            
        </collision>

        <inertial>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <mass value="0.1"/>
            <inertia 
                ixx="0.00026"
                iyy="0.00026"
                izz="0.00026"
                ixy="0.0"
                ixz="0.0"
                iyz="0.0"/>
        </inertial>

    </link>
    
    <gazebo reference="caster_wheel">
        <material>Gazebo/Black</material>
        <mu1 value="0.001"/>
        <mu2 value="0.001"/>
    </gazebo>
</robot>